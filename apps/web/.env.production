# Production API origin, baked into the bundle at build time (committed on
# purpose — it is public anyway, visible in every deployed bundle).
#
# Why this file exists: production deploys are `vite build` run locally +
# `wrangler pages deploy`, so Cloudflare Pages dashboard env vars never reach
# the build. Vite gives `.env.production` priority over `.env` in build mode,
# which makes production builds reproducible on any machine; `.env` (gitignored)
# now only affects `pnpm dev`.
VITE_API_BASE_URL="https://picsearch-api.maty892010.workers.dev/api/v1"
