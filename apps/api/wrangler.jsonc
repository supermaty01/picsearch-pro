{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "picsearch-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-01",
  "compatibility_flags": ["nodejs_compat"],
  // Workers AI binding — vision, embeddings, agent LLM, reranker (docs/adr/0002).
  // Route calls through AI Gateway: env.AI.run(model, input, { gateway: { id: env.AI_GATEWAY_ID } })
  "ai": {
    "binding": "AI",
  },
  "observability": {
    "enabled": true,
  },
  // Hourly retention sweep: public uploads expire after 24 h (services/cleanup.ts).
  "triggers": {
    "crons": ["0 * * * *"],
  },
  "vars": {
    "ENVIRONMENT": "development",
  },
  // Secrets (NEVER in this file — use `wrangler secret put` / .dev.vars locally):
  //   SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, AI_GATEWAY_ID
}
